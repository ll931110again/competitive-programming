# Third-party C++ dependencies.
# Googletest is fetched by `make test` (see scripts/fetch_googletest.sh).

COMPATIBLE_WITH = [
    "config//os:macos",
    "config//os:linux",
]

cxx_library(
    name = "gtest",
    srcs = glob(
        include = [
            "googletest/googletest/src/*.cc",
            "googletest/googlemock/src/*.cc",
        ],
        exclude = [
            "googletest/googletest/src/gtest-all.cc",
            "googletest/googletest/src/gtest_main.cc",
            "googletest/googlemock/src/gmock-all.cc",
            "googletest/googlemock/src/gmock_main.cc",
        ],
    ),
    exported_headers = glob([
        "googletest/googletest/include/gtest/*.h",
        "googletest/googlemock/include/gmock/*.h",
    ]),
    raw_headers = glob([
        "googletest/googletest/include/gtest/internal/*.h",
        "googletest/googletest/include/gtest/internal/custom/*.h",
        "googletest/googlemock/include/gmock/internal/*.h",
        "googletest/googlemock/include/gmock/internal/custom/*.h",
    ]),
    public_include_directories = [
        "googletest/googlemock",
        "googletest/googlemock/include",
        "googletest/googletest",
        "googletest/googletest/include",
    ],
    compiler_flags = [
        "-std=c++17",
    ],
    compatible_with = COMPATIBLE_WITH,
    link_style = "static",
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "gtest_main",
    srcs = [
        "googletest/googletest/src/gtest_main.cc",
    ],
    compatible_with = COMPATIBLE_WITH,
    link_style = "static",
    visibility = ["PUBLIC"],
    deps = [
        ":gtest",
    ],
)
